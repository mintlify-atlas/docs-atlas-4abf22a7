  "keyFeatures": [
    "Multi-role access: Administrator, Teacher (Docente), and Student (Estudiante) login",
    "Student membership management with BASIC, INTENSIVE, and PREMIUM plans",
    "Teacher contract management with salary and hours tracking",
    "Group (Grupo) management for organizing students and teachers",
    "Class reservation system supporting group classes and personalized private classes",
    "Class lifecycle management: create, start, finish, and rate classes",
    "File-based data persistence using Java serialization",
    "Swing-based graphical user interface with role-specific panels"
  ],
